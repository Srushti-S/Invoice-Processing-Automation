# ─────────────────────────────────────────────────────────────────────────────
# Pluggable LLM backend. Copy to `.env` and fill in. The whole system runs
# OFFLINE with zero key when LLM_PROVIDER=mock (the default if unset).
# Inventory + payment are ALWAYS local regardless of provider.
# ─────────────────────────────────────────────────────────────────────────────

# One of: mock | grok | groq | gemini | cerebras | mistral | ollama
LLM_PROVIDER=mock

# --- Groq (free, fast) ---  https://console.groq.com/keys
# LLM_PROVIDER=groq
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile

# --- xAI Grok (the case's named model; paid) ---  https://console.x.ai
# LLM_PROVIDER=grok
# XAI_API_KEY=xai-...
# XAI_MODEL=grok-3

# --- Google Gemini (free) ---  https://aistudio.google.com/apikey  (key starts with AIza...)
# LLM_PROVIDER=gemini
# GEMINI_API_KEY=AIza...
# GEMINI_MODEL=gemini-2.0-flash

# --- Cerebras (free, fast) ---  https://cloud.cerebras.ai  (key starts with csk-...)
# LLM_PROVIDER=cerebras
# CEREBRAS_API_KEY=csk-...
# CEREBRAS_MODEL=llama-3.3-70b

# --- Mistral (free tier) ---  https://console.mistral.ai
# LLM_PROVIDER=mistral
# MISTRAL_API_KEY=...
# MISTRAL_MODEL=mistral-small-latest

# --- Ollama (fully offline local model) ---  https://ollama.com  then: ollama pull qwen2.5
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=qwen2.5

# Approval threshold for "additional scrutiny" (USD)
APPROVAL_SCRUTINY_THRESHOLD=10000
